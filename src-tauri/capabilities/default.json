{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window with sidecar support",
  "windows": ["main", "spotlight"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "http:default",
    "fs:default",
    "global-shortcut:default"
  ]
}